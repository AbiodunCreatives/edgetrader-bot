# ─────────────────────────────────────────────────────────────────────────────
# Edge Trader Bot — environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────

# From @BotFather — required
BOT_TOKEN=

# Production only: public HTTPS URL Telegram will POST updates to.
# Leave blank in development (falls back to long polling).
# Example: https://mybot.fly.dev
WEBHOOK_URL=

# Optional extra security header for the webhook endpoint.
# If set, the same value is sent to Telegram and verified on receipt.
WEBHOOK_SECRET=

# Port Express listens on (default: 3000)
PORT=3000

# ── Anthropic / Claude ────────────────────────────────────────────────────────

# From console.anthropic.com — required
ANTHROPIC_API_KEY=

# Rolling 24-hour token budget across all Claude calls (input + output).
# Raise for higher traffic; lower to cap costs. Default: 100000
ANTHROPIC_DAILY_TOKEN_BUDGET=100000

# ── Supabase ──────────────────────────────────────────────────────────────────

# Project URL — from Settings → API in the Supabase dashboard
SUPABASE_URL=

# Service-role key — bypasses RLS (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis (Upstash or self-hosted) ────────────────────────────────────────────

# rediss://:<password>@<host>:<port>  (TLS)   — Upstash
# redis://:<password>@<host>:<port>           — plain
REDIS_URL=

# ── Market APIs (defaults are production endpoints) ───────────────────────────

POLYMARKET_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Bayse uses a fixed public endpoint; no API key required.

# ── Rate limiting (legacy per-minute window — kept for compatibility) ─────────

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=10

# ── Cache ─────────────────────────────────────────────────────────────────────

# Default Redis TTL for generic caches in seconds (default: 300 = 5 min)
CACHE_TTL_SECONDS=300

# ── Environment ───────────────────────────────────────────────────────────────

NODE_ENV=development

